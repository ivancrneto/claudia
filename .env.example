# Claudia configuration — 12-factor. Copy to a file OUTSIDE this repo and fill in.
#
# THE REPO IS PUBLIC: never commit real values. In production these come from your
# secret manager (Docker/K8s secrets, cloud secret manager, or an env file mounted
# outside the repo — see docs/DEPLOYMENT.md). This file lists keys only, no secrets.

# ---- runtime ----
CLAUDIA_ENV=dev            # dev | prod  (prod fails fast if required secrets are missing)
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# ---- voice backends ----
STT_BACKEND=stub           # stub | whisper
TTS_BACKEND=stub           # stub | piper

# ---- secrets (leave blank here; inject at runtime) ----
# Fernet key for the Account Vault. REQUIRED in prod. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=

# API-Football key for live fixtures. Optional (falls back to the offline stub).
API_FOOTBALL_KEY=
FOOTBALL_SEASON=2026
